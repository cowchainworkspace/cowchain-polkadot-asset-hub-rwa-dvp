# =====================================================================
# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit keys.
# =====================================================================

# --- Polkadot Hub TestNet (chain id 420420417, native token PAS) ---
# Verify the chain id is still 420420417 with: cast chain-id --rpc-url $HUB_TESTNET_RPC_URL
HUB_TESTNET_RPC_URL=https://eth-rpc-testnet.polkadot.io/
HUB_TESTNET_CHAIN_ID=420420417

# Deployer key for Polkadot Hub (EVM / secp256k1).
# Generate locally with: cast wallet new
# Fund the printed address at: https://faucet.polkadot.io/  (select "Polkadot Hub TestNet")
HUB_DEPLOYER_PRIVATE_KEY=

# --- KILT Peregrine testnet (verifiable-credential attester) ---
KILT_WSS_ENDPOINT=wss://peregrine.kilt.io
# Attester account seed/mnemonic (sr25519). Fund at: https://faucet.kilt.io/
KILT_ATTESTER_MNEMONIC=
# The attester's sr25519 public key (0x-prefixed, 32 bytes) that the on-chain
# KiltIdentityBridge will trust and verify via the System precompile (0x900).
KILT_ATTESTER_SR25519_PUBKEY=

# --- Frontend (apps/web) — only NEXT_PUBLIC_* values reach the browser ---
NEXT_PUBLIC_HUB_TESTNET_RPC_URL=https://eth-rpc-testnet.polkadot.io/
NEXT_PUBLIC_HUB_CHAIN_ID=420420417
